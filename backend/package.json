{
  "name": "robayer-wealthlab-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker API for Robayer WealthLab (Version 1.2 Sprint 3: newsletter, contact, consultation).",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "db:apply:local": "wrangler d1 execute robayer-wealthlab-db --local --file=./database/schema.sql",
    "db:apply:remote": "wrangler d1 execute robayer-wealthlab-db --remote --file=./database/schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "workerd@1.20260701.1": true,
    "sharp@0.34.5": true
  }
}
